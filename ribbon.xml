<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui" onLoad="OnAddinLoad">
    <ribbon startFromScratch="false">
        <tabs>
            <tab id="wpsAddinTab" label="量效助手">

                <group id="groupGtj" label="格式处理">
                    <button id="btnCleanGtj" label="去底色+清空格转数值" getImage="GetImage" onAction="OnAction" size="large" />
                    <button id="btnCleanFormat" label="去底色+11号字" getImage="GetImage" onAction="OnAction" size="large" />
                    <button id="btnFormatTool" label="格式清洗弹窗" getImage="GetImage" onAction="OnAction" size="large" /> 
                    <button id="btnCalcFormula" label="录入计算式" getImage="GetImage" onAction="OnAction" size="large" />
                    <separator id="sep1" /> 
                </group>

                <group id="groupOthers" label="数据处理">
                    <button id="btnCopyID" label="复制拼接ID" getImage="GetImage" onAction="OnAction" size="large" />
                    <button id="btnToggleZero" label="显示/隐藏0值" getImage="GetImage" onAction="OnAction" size="large" />
                    <button id="btnTraceRef" label="公式追踪" getImage="GetImage" onAction="OnAction" size="large" />

                    <separator id="sep1" /> 

                </group>

                <group id="groupCustom" label="个性工具栏">


                    <button id="btnPivotSummary" label="数据透析表" getImage="GetImage" onAction="OnAction" size="large" />

                    <separator id="sep1" />                     
                </group>

            </tab>
        </tabs>
    </ribbon>
</customUI>